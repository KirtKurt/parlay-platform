+def test_unaligned_t_minus_ten_gate_uses_prior_heartbeat_not_late_start():
+    settings = Settings()
+    events = [
+        {
+            "id": "unaligned",
+            "provider_sport_key": "tennis_atp_test",
+            "commence_time": "2026-07-23T08:07:00Z",
+        }
+    ]
+    row = build_collection_schedule(
+        events,
+        settings,
+        now=datetime(2026, 7, 22, 22, 0, tzinfo=timezone.utc),
+    )["slates"][0]
+    assert row["collection_start_exact_utc"] == "2026-07-22T22:07:00+00:00"
+    assert row["collection_start_utc"] == "2026-07-22T22:00:00+00:00"
+    assert row["collection_starts_no_later_than_exact_gate"] is True
+    assert row["status"] == "ACTIVE"
+
+
+def test_collection_gate_is_never_rounded_after_exact_t_minus_ten():
+    settings = Settings()
+    for minute in range(60):
+        events = [
+            {
+                "id": f"m-{minute}",
+                "provider_sport_key": "tennis_wta_test",
+                "commence_time": f"2026-07-23T09:{minute:02d}:00Z",
+            }
+        ]
+        row = build_collection_schedule(
+            events,
+            settings,
+            now=datetime(2026, 7, 22, 0, 0, tzinfo=timezone.utc),
+        )["slates"][0]
+        scheduled = datetime.fromisoformat(row["collection_start_utc"])
+        exact = datetime.fromisoformat(row["collection_start_exact_utc"])
+        assert scheduled <= exact
+        assert (exact - scheduled).total_seconds() < 15 * 60
